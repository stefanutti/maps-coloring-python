<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d13" for="edge" attr.name="color" attr.type="string" />
  <key id="d12" for="edge" attr.name="thickness" attr.type="long" />
  <key id="d11" for="edge" attr.name="multiplicity" attr.type="long" />
  <key id="d10" for="edge" attr.name="weight" attr.type="long" />
  <key id="d9" for="node" attr.name="b" attr.type="long" />
  <key id="d8" for="node" attr.name="g" attr.type="long" />
  <key id="d7" for="node" attr.name="r" attr.type="long" />
  <key id="d6" for="node" attr.name="color" attr.type="string" />
  <key id="d5" for="node" attr.name="size" attr.type="long" />
  <key id="d4" for="node" attr.name="degree" attr.type="long" />
  <key id="d3" for="node" attr.name="z" attr.type="double" />
  <key id="d2" for="node" attr.name="y" attr.type="double" />
  <key id="d1" for="node" attr.name="x" attr.type="double" />
  <key id="d0" for="node" attr.name="type" attr.type="string" />
  <graph edgedefault="undirected">
    <node id="1">
      <data key="d0">original</data>
      <data key="d1">-1.0</data>
      <data key="d2">0.0</data>
      <data key="d3">0.0</data>
      <data key="d4">1</data>
      <data key="d5">10</data>
      <data key="d6">red</data>
      <data key="d7">255</data>
      <data key="d8">0</data>
      <data key="d9">0</data>
    </node>
    <node id="2">
      <data key="d0">original</data>
      <data key="d1">1.0</data>
      <data key="d2">0.0</data>
      <data key="d3">0.0</data>
      <data key="d4">1</data>
      <data key="d5">10</data>
      <data key="d6">red</data>
      <data key="d7">255</data>
      <data key="d8">0</data>
      <data key="d9">0</data>
    </node>
    <edge source="1" target="2">
      <data key="d10">3</data>
      <data key="d11">3</data>
      <data key="d12">3</data>
      <data key="d13">red</data>
    </edge>
  </graph>
</graphml>
